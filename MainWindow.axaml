<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:CCUTrade"
        x:Class="CCUTrade.MainWindow"
        Width="1100" Height="800"
        Title="CCUTrade - 中正二手校園交易平台"
        Background="#F5F7FA">

	<Grid RowDefinitions="Auto, *">

		<Border Grid.Row="0" Background="#FFEAA7" Height="35" VerticalAlignment="Center">
			<Border Padding="10,0">
				<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
					<TextBlock x:Name="NotificationTextBlock" Text="🔔 歡迎來到 CCU 二手交易平台，請先完成校內帳號認證！" FontWeight="Bold" Foreground="#D63031"/>
				</StackPanel>
			</Border>
		</Border>

		<Grid Grid.Row="1">
			<Grid x:Name="LoginOverlayPage" Background="#E0E6ED" ZIndex="99" IsVisible="True">
				<Border Background="White" Width="450" Height="380" CornerRadius="12" BoxShadow="0 10 30 0 #33000000" VerticalAlignment="Center" HorizontalAlignment="Center">
					<Border Padding="40">
						<StackPanel Spacing="20" VerticalAlignment="Center">
							<TextBlock Text="CCUTrade" FontSize="32" FontWeight="Black" Foreground="#2C3E50" HorizontalAlignment="Center"/>
							<TextBlock Text="中正大學校園二手交易市集" FontSize="16" Foreground="#7F8C8D" HorizontalAlignment="Center" Margin="0,0,0,10"/>

							<Separator/>

							<StackPanel Spacing="5">
								<TextBlock Text="學生姓名" FontSize="14" FontWeight="Bold" Foreground="#34495E"/>
								<TextBox x:Name="StudentNameTextBox" Watermark="請輸入真實姓名" Height="40" VerticalContentAlignment="Center"/>
							</StackPanel>

							<StackPanel Spacing="5">
								<TextBlock Text="學校 Gmail 認證" FontSize="14" FontWeight="Bold" Foreground="#34495E"/>
								<TextBox x:Name="SchoolEmailTextBox" Watermark="例如: b11136XXX@ccu.edu.tw" Height="40" VerticalContentAlignment="Center"/>
							</StackPanel>

							<Button x:Name="RegisterOrLoginButton" Content="使用學校 Gmail 認證並登入"
                                    Background="#2980B9" Foreground="White" Height="45" CornerRadius="6"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                    FontWeight="Bold" Click="RegisterOrLoginButton_Click"/>
						</StackPanel>
					</Border>
				</Border>
			</Grid>

			<Grid ColumnDefinitions="Auto, *">

				<Border Grid.Column="0" Background="#2C3E50" Width="220" x:Name="SideMenuPanel">
					<Grid RowDefinitions="Auto, *, Auto">
						<Border Grid.Row="0" Padding="20">
							<StackPanel Spacing="10">
								<StackPanel Orientation="Horizontal" Spacing="10">
									<TextBlock Text="☰" FontSize="24" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
									<TextBlock Text="CCU功能選單" FontSize="18" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
								</StackPanel>
								<TextBlock x:Name="CurrentUserTextBlock" Text="未登入" FontSize="11" Foreground="#BDC3C7" TextWrapping="Wrap"/>
							</StackPanel>
						</Border>

						<StackPanel Grid.Row="1" Spacing="5" Margin="10,0">
							<Button Content="🏠 校園首頁大廳" Background="Transparent" Foreground="White" HorizontalAlignment="Stretch" Padding="15,12" HorizontalContentAlignment="Left" Click="OnGoToHomePage_Click"/>
							<Button Content="🎒 智慧賣家管理中心" Background="Transparent" Foreground="White" HorizontalAlignment="Stretch" Padding="15,12" HorizontalContentAlignment="Left" Click="OnGoToSellerPage_Click"/>
						</StackPanel>

						<Border Grid.Row="2" Background="#34495E" Margin="10" Padding="10" CornerRadius="6">
							<StackPanel Spacing="5">
								<TextBlock Text="⚠️ 安全交易提醒" FontSize="12" FontWeight="Bold" Foreground="#E74C3C"/>
								<TextBlock Text="建議約在活中、警衛室等公開明亮場所面交。請勿單占前往偏僻校區。" FontSize="11" Foreground="#ECF0F1" TextWrapping="Wrap"/>
							</StackPanel>
						</Border>
					</Grid>
				</Border>

				<Grid Grid.Column="1" Margin="20">
					<TabControl x:Name="MainWebsiteTabControl" TabStripPlacement="Top">
						<TabControl.Styles>
							<Style Selector="TabItem">
								<Setter Property="IsVisible" Value="False"/>
							</Style>
						</TabControl.Styles>

						<TabItem>
							<Grid RowDefinitions="Auto, *">
								<Border Grid.Row="0" Background="White" Padding="15" CornerRadius="8" Margin="0,0,0,15" BoxShadow="0 2 10 0 #10000000">
									<StackPanel Spacing="10">
										<TextBlock Text="🔍 智慧關鍵字與多條件快速篩選" FontSize="16" FontWeight="Bold" Foreground="#2C3E50"/>

										<Grid ColumnDefinitions="*, 10, Auto, 10, Auto" RowDefinitions="Auto, 10, Auto" Margin="0,5,0,0">
											<TextBox Grid.Column="0" Grid.Row="0" x:Name="SearchTextBox" Watermark="輸入任何關鍵字（名稱、描述、賣家、信箱、評價等）自動智慧匹配..." TextChanged="SearchTextBox_TextChanged" Height="40" VerticalContentAlignment="Center"/>
											<Button Grid.Column="2" Grid.Row="0" Content="重新整理" Click="RefreshButton_Click" Background="#27AE60" Foreground="White" Width="90" Height="40" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
											<Button Grid.Column="4" Grid.Row="0" Content="清除條件" Click="ClearSearchButton_Click" Background="#7F8C8D" Foreground="White" Width="90" Height="40" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>

											<StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="5" Orientation="Horizontal" Spacing="10">
												<ComboBox x:Name="FilterCategoryListBox" Width="130" SelectionChanged="FilterCategoryListBox_SelectionChanged">
													<ListBoxItem Content="全部"/>
													<ListBoxItem Content="課本"/>
													<ListBoxItem Content="宿舍用品"/>
													<ListBoxItem Content="腳踏車"/>
													<ListBoxItem Content="電子產品"/>
													<ListBoxItem Content="其他"/>
												</ComboBox>
												<ComboBox x:Name="CampusSectionFilterListBox" Width="140" SelectionChanged="CampusSectionFilterListBox_SelectionChanged">
													<ListBoxItem Content="全部"/>
													<ListBoxItem Content="一般商品"/>
													<ListBoxItem Content="畢業傳承商品"/>
												</ComboBox>
												<ComboBox x:Name="StatusFilterListBox" Width="110" SelectionChanged="StatusFilterListBox_SelectionChanged">
													<ListBoxItem Content="販售中"/>
													<ListBoxItem Content="已售出"/>
												</ComboBox>
												<TextBox x:Name="DepartmentSearchTextBox" Watermark="篩選科系" Width="110" TextChanged="DepartmentSearchTextBox_TextChanged"/>
												<TextBox x:Name="CourseSearchTextBox" Watermark="篩選課程" Width="110" TextChanged="CourseSearchTextBox_TextChanged"/>
												<TextBox x:Name="MinPriceTextBox" Watermark="最低$" Width="80" TextChanged="PriceRangeTextBox_TextChanged"/>
												<TextBlock Text="~" VerticalAlignment="Center"/>
												<TextBox x:Name="MaxPriceTextBox" Watermark="最高$" Width="80" TextChanged="PriceRangeTextBox_TextChanged"/>
											</StackPanel>
										</Grid>
									</StackPanel>
								</Border>

								<ScrollViewer Grid.Row="1">
									<StackPanel Spacing="20">
										<Border Background="White" Padding="15" CornerRadius="8" BoxShadow="0 2 10 0 #10000000">
											<StackPanel Spacing="10">
												<TextBlock Text="🔥 熱門校園商品與智慧搜尋結果（依最新時間排行）" FontSize="18" FontWeight="Bold" Foreground="#E67E22"/>
												<ListBox x:Name="ProductList" Height="300" Background="#F8F9FA" BorderBrush="#BDC3C7" BorderThickness="1"/>
												<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,5,0,0">
													<Button Content="📂 載入所選商品至管理區" Click="LoadSelectedProductButton_Click" Background="#2980B9" Foreground="White" Padding="10,5"/>
												</StackPanel>
											</StackPanel>
										</Border>

										<Grid ColumnDefinitions="*, *">
											<Border Grid.Column="0" Background="White" Padding="15" CornerRadius="8" Margin="0,0,10,0" BoxShadow="0 2 10 0 #10000000">
												<StackPanel Spacing="10">
													<TextBlock Text="🔔 智慧願望清單關鍵字追蹤" FontSize="16" FontWeight="Bold" Foreground="#8E44AD"/>
													<Grid ColumnDefinitions="*, Auto, Auto">
														<TextBox x:Name="WishlistKeywordTextBox" Watermark="輸入想買的關鍵字，如: 管理學" Margin="0,0,5,0"/>
														<Button Grid.Column="1" Content="加入" Click="AddWishlistButton_Click" Background="#8E44AD" Foreground="White" Margin="0,0,5,0"/>
														<Button Grid.Column="2" Content="刪除選取" Click="DeleteWishlistButton_Click" Background="#C0392B" Foreground="White"/>
													</Grid>
													<ListBox x:Name="WishlistList" Height="120" Background="#F8F9FA" Margin="0,10,0,0"/>
												</StackPanel>
											</Border>

											<Border Grid.Column="1" CornerRadius="8" BoxShadow="0 2 10 0 #10000000" Margin="10,0,0,0">
												<Border.Background>
													<LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
														<GradientStop Color="#4A00E0" Offset="0.0"/>
														<GradientStop Color="#8E2DE2" Offset="1.0"/>
													</LinearGradientBrush>
												</Border.Background>
												<Border Padding="20">
													<StackPanel Spacing="10" VerticalAlignment="Center">
														<TextBlock Text="🎓 畢業出清與學長姐薪火傳承專區" FontSize="18" FontWeight="Bold" Foreground="White"/>
														<TextBlock Text="大四畢業季來臨！二手教科書、宿舍打包紙箱、特約機車行安全帽應有盡有。請在上方的【校園分區】下拉選單中篩選「畢業傳承商品」，即可一鍵探索所有學長姐留下的寶藏物資！" FontSize="13" Foreground="#E0E6ED" TextWrapping="Wrap"/>
													</StackPanel>
												</Border>
											</Border>
										</Grid>
									</StackPanel>
								</ScrollViewer>
							</Grid>
						</TabItem>

						<TabItem>
							<ScrollViewer>
								<Grid ColumnDefinitions="2*, 15, 1*" RowDefinitions="Auto, 15, Auto" Margin="5">

									<Border Grid.Column="0" Grid.Row="0" Background="White" Padding="20" CornerRadius="8" BoxShadow="0 2 10 0 #10000000">
										<StackPanel Spacing="12">
											<TextBlock Text="🎒 智慧商品管理與上架系統（商品有效期限：30天機制自動防呆）" FontSize="18" FontWeight="Bold" Foreground="#2C3E50"/>
											<Separator/>

											<Grid ColumnDefinitions="*, 15, *" RowDefinitions="Auto, 15, Auto, 15, Auto, 15, Auto, 15, Auto">
												<StackPanel Grid.Column="0" Grid.Row="0" Spacing="5">
													<TextBlock Text="商品名稱 *" FontSize="13" FontWeight="Bold"/>
													<TextBox x:Name="NameTextBox" Watermark="例如: 大四二手原文書"/>
												</StackPanel>
												<StackPanel Grid.Column="2" Grid.Row="0" Spacing="5">
													<TextBlock Text="價格 ($) *" FontSize="13" FontWeight="Bold"/>
													<TextBox x:Name="PriceTextBox" Watermark="請輸入數字"/>
												</StackPanel>

												<StackPanel Grid.Column="0" Grid.Row="2" Spacing="5">
													<TextBlock Text="二手分類 *" FontSize="13" FontWeight="Bold"/>
													<ComboBox x:Name="CategoryListBox" HorizontalAlignment="Stretch">
														<ListBoxItem Content="課本"/>
														<ListBoxItem Content="宿舍用品"/>
														<ListBoxItem Content="腳踏車"/>
														<ListBoxItem Content="電子產品"/>
														<ListBoxItem Content="其他"/>
													</ComboBox>
												</StackPanel>
												<StackPanel Grid.Column="2" Grid.Row="2" Spacing="5">
													<TextBlock Text="校園市集分區 *" FontSize="13" FontWeight="Bold"/>
													<ComboBox x:Name="CampusSectionListBox" HorizontalAlignment="Stretch">
														<ListBoxItem Content="一般商品"/>
														<ListBoxItem Content="畢業傳承商品"/>
													</ComboBox>
												</StackPanel>

												<StackPanel Grid.Column="0" Grid.Row="4" Spacing="5">
													<TextBlock Text="賣家科系 *" FontSize="13" FontWeight="Bold"/>
													<TextBox x:Name="DepartmentTextBox" Watermark="例如: 資管系"/>
												</StackPanel>
												<StackPanel Grid.Column="2" Grid.Row="4" Spacing="5">
													<TextBlock Text="對應課程名稱 *" FontSize="13" FontWeight="Bold"/>
													<TextBox x:Name="CourseNameTextBox" Watermark="例如: 管理學"/>
												</StackPanel>

												<StackPanel Grid.Column="0" Grid.Row="6" Spacing="5">
													<TextBlock Text="賣家姓名 *" FontSize="13" FontWeight="Bold"/>
													<TextBox x:Name="SellerNameTextBox" Watermark="請輸入姓名"/>
												</StackPanel>
												<StackPanel Grid.Column="2" Grid.Row="6" Spacing="5">
													<TextBlock Text="聯絡方式 *" FontSize="13" FontWeight="Bold"/>
													<TextBox x:Name="ContactInfoTextBox" Watermark="手機、LINE 或 FB"/>
												</StackPanel>

												<StackPanel Grid.Column="0" Grid.Row="8" Grid.ColumnSpan="3" Spacing="5">
													<TextBlock Text="指定交易面交地點 *" FontSize="13" FontWeight="Bold"/>
													<TextBox x:Name="LocationTextBox" Watermark="請輸入面交地點（或從右側安全推薦名單選取）"/>
												</StackPanel>
											</Grid>

											<StackPanel Spacing="5" Margin="0,5,0,0">
												<TextBlock Text="商品詳細描述" FontSize="13" FontWeight="Bold"/>
												<TextBox x:Name="DescriptionTextBox" Watermark="描述新舊狀況..." Height="70" AcceptsReturn="True" TextWrapping="Wrap"/>
											</StackPanel>

											<StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" Margin="0,10,0,0">
												<Button Content="❌ 刪除選定商品" Click="DeleteProductButton_Click" Background="#C0392B" Foreground="White" Padding="15,10" FontWeight="Bold"/>
												<Button Content="💾 儲存修改" Click="UpdateProductButton_Click" Background="#F39C12" Foreground="White" Padding="15,10" FontWeight="Bold"/>
												<Button Content="🚀 確認發布商品" Click="AddProduct_Click" Background="#27AE60" Foreground="White" Padding="25,10" FontWeight="Bold"/>
											</StackPanel>
										</StackPanel>
									</Border>

									<StackPanel Grid.Column="2" Grid.Row="0" Spacing="15">
										<Border Background="#EDF2F7" Padding="15" CornerRadius="8" BorderBrush="#CBD5E0" BorderThickness="1">
											<StackPanel Spacing="8">
												<TextBlock Text="🛡️ 中正校內推薦安全面交地" FontSize="14" FontWeight="Bold" Foreground="#2C3E50"/>
												<TextBlock Text="（點擊自動填入，確保人身與財產安全）" FontSize="11" Foreground="#718096"/>
												<ListBox x:Name="RecommendedMeetingLocationListBox" Height="140" SelectionChanged="RecommendedMeetingLocationListBox_SelectionChanged">
													<ListBoxItem Content="校門口大門警衛室"/>
													<ListBoxItem Content="活動中心中庭廣場"/>
													<ListBoxItem Content="CCU 總圖書館正門口"/>
													<ListBoxItem Content="噴水池圓環大草皮"/>
													<ListBoxItem Content="管理學院一館大廳"/>
												</ListBox>
											</StackPanel>
										</Border>

										<Border Background="White" Padding="15" CornerRadius="8" BoxShadow="0 2 10 0 #10000000">
											<StackPanel Spacing="10">
												<TextBlock Text="⚙️ 商品狀態變更" FontSize="14" FontWeight="Bold" Foreground="#2C3E50"/>
												<Button Content="🤝 標記此商品為【已售出】" Click="MarkAsSoldButton_Click" Background="#2980B9" Foreground="White" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="10"/>
											</StackPanel>
										</Border>
									</StackPanel>

									<Border Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="2" Background="#FFF5F5" BorderBrush="#FEB2B2" BorderThickness="2" Padding="20" CornerRadius="8">
										<StackPanel Spacing="12">
											<StackPanel Orientation="Horizontal" Spacing="10">
												<TextBlock Text="⭐ 滿意度交易評價系統" FontSize="16" FontWeight="Bold" Foreground="#9B1C1C"/>
												<TextBlock Text="（安全隱藏防線：僅在網站交易完成、商品標記為已售出後才開放激活）" FontSize="12" Foreground="#C53030" VerticalAlignment="Center"/>
											</StackPanel>
											<Separator Background="#FEE2E2"/>

											<Grid ColumnDefinitions="Auto, 15, *" RowDefinitions="Auto">
												<StackPanel Grid.Column="0" Grid.Row="0" Spacing="5">
													<TextBlock Text="星等評分 *" FontSize="13" FontWeight="Bold"/>
													<ComboBox x:Name="ReviewRatingListBox" Width="120">
														<ListBoxItem Content="5"/>
														<ListBoxItem Content="4"/>
														<ListBoxItem Content="3"/>
														<ListBoxItem Content="2"/>
														<ListBoxItem Content="1"/>
													</ComboBox>
												</StackPanel>
												<StackPanel Grid.Column="2" Grid.Row="0" Spacing="5">
													<TextBlock Text="交易評語 / 面交心得回饋 *" FontSize="13" FontWeight="Bold"/>
													<TextBox x:Name="ReviewCommentTextBox" Watermark="請輸入對本次校內面交的評價或賣家態度反饋..."/>
												</StackPanel>
											</Grid>

											<StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" Margin="0,10,0,0">
												<Button Content="🔍 載入該商品歷史評價" Click="LoadReviewButton_Click" Background="#4A5568" Foreground="White" Padding="12,8"/>
												<Button Content="🔒 儲存並送出滿意度評價" Click="SaveReviewButton_Click" Background="#9B1C1C" Foreground="White" Padding="15,8" FontWeight="Bold"/>
											</StackPanel>
										</StackPanel>
									</Border>
								</Grid>
							</ScrollViewer>
						</TabItem>
					</TabControl>
				</Grid>

			</Grid>
		</Grid>
	</Grid>
</Window>